<Window x:Class="DeskViz.App.Widgets.GpuWidget.GpuWidgetSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskViz.App.Widgets.GpuWidget"
        mc:Ignorable="d"
        Title="GPU Widget Settings" Height="400" Width="400"
        Background="#1F1F1F"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="GPU Widget Settings" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,20"/>

        <!-- Settings Content -->
        <StackPanel Grid.Row="1">
            <!-- GPU Selection -->
            <TextBlock Text="GPU Selection" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,0,0,10"/>
            
            <ComboBox x:Name="GpuSelectionComboBox" 
                      ItemsSource="{Binding AvailableGpus}"
                      SelectedIndex="{Binding SelectedGpuIndex}"
                      Foreground="White" Background="#333333" BorderBrush="#555555"
                      Margin="0,0,0,15">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Type}" FontWeight="Bold" Margin="0,0,5,0" Foreground="Black"/>
                            <TextBlock Text="{Binding Name}" Foreground="Black"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#F0F0F0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Padding" Value="5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#4FC3F7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>
            
            <!-- Display Options -->
            <TextBlock Text="Display Options" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,0,0,10"/>
            
            <CheckBox x:Name="ShowTemperatureCheckBox" Content="Show Temperature" 
                      IsChecked="{Binding ShowTemperature}"
                      Foreground="White" Margin="0,5"/>
            
            <CheckBox x:Name="ShowPowerCheckBox" Content="Show Power Usage" 
                      IsChecked="{Binding ShowPower}"
                      Foreground="White" Margin="0,5"/>
            
            <CheckBox x:Name="ShowMemoryCheckBox" Content="Show Memory Usage" 
                      IsChecked="{Binding ShowMemory}"
                      Foreground="White" Margin="0,5"/>
            
            <CheckBox x:Name="ShowClockSpeedCheckBox" Content="Show Clock Speed" 
                      IsChecked="{Binding ShowClockSpeed}"
                      Foreground="White" Margin="0,5"/>

            <!-- Temperature Unit -->
            <TextBlock Text="Temperature Unit" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,20,0,10"/>
            
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="CelsiusRadio" Content="Celsius (°C)" 
                            IsChecked="{Binding IsCelsius}"
                            Foreground="White" Margin="0,0,20,0"/>
                <RadioButton x:Name="FahrenheitRadio" Content="Fahrenheit (°F)" 
                            IsChecked="{Binding IsCelsius, Converter={StaticResource InvertBooleanConverter}}"
                            Foreground="White"/>
            </StackPanel>

            <!-- Update Interval -->
            <TextBlock Text="Update Interval" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,20,0,10"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Slider x:Name="UpdateIntervalSlider" Grid.Column="0"
                        Minimum="1" Maximum="10" 
                        Value="{Binding UpdateInterval}"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        Margin="0,0,10,0"/>
                
                <TextBlock Grid.Column="1" Foreground="White" Width="50">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} sec">
                            <Binding Path="Value" ElementName="UpdateIntervalSlider"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,10,0" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Click="OkButton_Click"/>
            <Button Content="Cancel" Width="80" Height="30" 
                    Background="#555555" Foreground="White" BorderThickness="0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>