<UserControl x:Class="DeskViz.App.Widgets.GpuWidget.GpuWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeskViz.App.Widgets.GpuWidget"
             xmlns:controls="clr-namespace:DeskViz.App.Controls"
             xmlns:converters="clr-namespace:DeskViz.App.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:TemperatureToStringConverter x:Key="TempToString" />
    </UserControl.Resources>
    
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Configure Widget" Click="ConfigButton_Click" />
        </ContextMenu>
    </UserControl.ContextMenu>
    
    <Border Background="#1F1F1F" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#2A2A2A" CornerRadius="5,5,0,0" Padding="15,10">
                <StackPanel>
                    <TextBlock Text="GPU Monitor" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding GpuName}" FontSize="12" Foreground="#B0B0B0" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                <StackPanel>
                    <!-- GPU Usage -->
                    <Grid Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GPU Usage" FontSize="14" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="{Binding GpuUsage, StringFormat='{}{0:F1}%'}" 
                                       FontSize="14" FontWeight="Bold" Foreground="#4FC3F7"/>
                        </Grid>
                        
                        <controls:DeskVizProgressBar Grid.Row="1" Height="20" Margin="0,5,0,0"
                                                     Value="{Binding GpuUsage}" Maximum="100"
                                                     ProgressBrush="#4FC3F7"
                                                     BarHeight="20"
                                                     ShowText="False"/>
                    </Grid>

                    <!-- Temperature and Power -->
                    <Grid Margin="0,0,0,15" Visibility="{Binding ShowTemperature, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Temperature -->
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Temperature" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="{Binding GpuTemperature, Converter={StaticResource TempToString}}"
                                       FontSize="16" FontWeight="Bold" Foreground="#FF9800"/>
                        </StackPanel>
                        
                        <!-- Power -->
                        <StackPanel Grid.Column="1" Margin="5,0,0,0" 
                                    Visibility="{Binding ShowPower, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Power" FontSize="12" Foreground="#B0B0B0"/>
                            <TextBlock Text="{Binding GpuPower, StringFormat='{}{0:F1} W'}" 
                                       FontSize="16" FontWeight="Bold" Foreground="#8BC34A"/>
                        </StackPanel>
                    </Grid>

                    <!-- Memory Usage -->
                    <Grid Margin="0,0,0,15" Visibility="{Binding ShowMemory, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Memory Usage" FontSize="14" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="{Binding GpuMemoryUsagePercent, StringFormat='{}{0:F1}%'}" 
                                       FontSize="14" FontWeight="Bold" Foreground="#E91E63"/>
                        </Grid>
                        
                        <controls:DeskVizProgressBar Grid.Row="1" Height="20" Margin="0,5,0,5"
                                                     Value="{Binding GpuMemoryUsagePercent}" Maximum="100"
                                                     ProgressBrush="#E91E63"
                                                     BarHeight="20"
                                                     ShowText="False"/>
                        
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Used / Total" FontSize="11" Foreground="#B0B0B0"/>
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="#B0B0B0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1} GB / {1:F1} GB">
                                        <Binding Path="GpuMemoryUsedGB"/>
                                        <Binding Path="GpuMemoryTotalGB"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <!-- Clock Speed -->
                    <Grid Margin="0,0,0,15" Visibility="{Binding ShowClockSpeed, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Core Clock" FontSize="12" Foreground="#B0B0B0"/>
                        <TextBlock Grid.Column="1" Text="{Binding GpuClockSpeed, StringFormat='{}{0:F0} MHz'}" 
                                   FontSize="14" FontWeight="Bold" Foreground="#9C27B0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#2A2A2A" CornerRadius="0,0,5,5" Padding="10,5">
                <TextBlock Text="{Binding LastUpdateTime, StringFormat='Updated: {0:HH:mm:ss}'}" 
                           FontSize="10" Foreground="#808080" HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</UserControl>