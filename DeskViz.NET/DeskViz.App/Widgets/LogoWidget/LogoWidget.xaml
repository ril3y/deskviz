<UserControl x:Class="DeskViz.App.Widgets.LogoWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DeskViz.App.Widgets"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="200"
             >
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings..." Click="LogoSettingsMenuItem_Click"/>
            <!-- Add other widget-specific actions here if needed -->
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <Image x:Name="LogoImage"
               Source="{Binding ImageSource}"
               Width="{Binding LogoWidth, TargetNullValue={x:Static System:Double.NaN}}" 
               Height="{Binding LogoHeight, TargetNullValue={x:Static System:Double.NaN}}"
               Stretch="{Binding LogoStretch}"
               HorizontalAlignment="{Binding LogoHorizontalAlignment}"
               VerticalAlignment="{Binding LogoVerticalAlignment}"/>
        <!-- TargetNullValue=Double.NaN allows the binding to reset to 'Auto' size if the value is null -->
    </Grid>
</UserControl>
