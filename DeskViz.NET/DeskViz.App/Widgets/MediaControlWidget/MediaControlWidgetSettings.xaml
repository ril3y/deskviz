<Window x:Class="DeskViz.App.Widgets.MediaControlWidget.MediaControlWidgetSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskViz.App.Widgets.MediaControlWidget"
        mc:Ignorable="d"
        Title="Media Control Widget Settings" Height="400" Width="400"
        Background="#1F1F1F"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Media Control Widget Settings" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,20"/>

        <!-- Settings Content -->
        <StackPanel Grid.Row="1">
            <!-- Display Settings -->
            <TextBlock Text="Display Settings" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,0,0,10"/>
            
            <CheckBox Content="Show Widget Title ('Media Control')" 
                      IsChecked="{Binding ShowTitle}" 
                      Foreground="White" Margin="0,5"/>
            
            <CheckBox Content="Show App Name Subtitle" 
                      IsChecked="{Binding ShowSubtitle}" 
                      Foreground="White" Margin="0,5,0,15"/>

            <!-- Information -->
            <TextBlock Text="Widget Information" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,10,0,10"/>
            
            <TextBlock Text="This widget provides control over Windows media sessions." 
                       Foreground="White" Margin="0,0,0,5" TextWrapping="Wrap"/>
            
            <TextBlock Text="Compatible with Spotify, YouTube, VLC, Windows Media Player, and other media apps that support Windows Media Transport Controls." 
                       Foreground="#B0B0B0" Margin="0,0,0,15" TextWrapping="Wrap" FontSize="11"/>

            <!-- Features -->
            <TextBlock Text="Features" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,10,0,10"/>
            
            <StackPanel Margin="10,0,0,0">
                <TextBlock Text="• Play, pause, stop, and skip tracks" Foreground="White" Margin="0,2"/>
                <TextBlock Text="• Display current song information" Foreground="White" Margin="0,2"/>
                <TextBlock Text="• Show album artwork" Foreground="White" Margin="0,2"/>
                <TextBlock Text="• Touch-friendly volume control" Foreground="White" Margin="0,2"/>
                <TextBlock Text="• Real-time playback progress" Foreground="White" Margin="0,2"/>
            </StackPanel>

            <!-- Notes -->
            <TextBlock Text="Notes" FontSize="14" FontWeight="SemiBold" 
                       Foreground="#B0B0B0" Margin="0,15,0,10"/>
            
            <TextBlock Text="• Volume control may be limited depending on the media application" 
                       Foreground="#B0B0B0" Margin="0,2" FontSize="11" TextWrapping="Wrap"/>
            <TextBlock Text="• Some media apps may not support all controls" 
                       Foreground="#B0B0B0" Margin="0,2" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Width="80" Height="30" 
                    Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>