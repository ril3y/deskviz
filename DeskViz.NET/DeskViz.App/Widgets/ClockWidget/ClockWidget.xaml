<UserControl x:Class="DeskViz.App.Widgets.ClockWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="200"
             Background="#333333" Foreground="White" Padding="10">
             
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Settings" Click="SettingsMenuItem_Click"/>
            <!-- Add other widget-specific actions here if needed -->
        </ContextMenu>
    </UserControl.ContextMenu>
    
    <Grid>
        <TextBlock x:Name="TimeTextBlock"
                   Text="{Binding CurrentTime}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="{Binding ClockFontSize}"
                   FontWeight="Bold"/>
    </Grid>
</UserControl>
