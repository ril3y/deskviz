<UserControl x:Class="DeskViz.App.Widgets.ClockWidgetSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DeskViz.App.Widgets"
             xmlns:core="clr-namespace:DeskViz.Core"
             mc:Ignorable="d"
             d:DesignHeight="250" d:DesignWidth="350">
    
    <Grid Margin="10" Background="#444444">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Clock Settings" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="White"/>
        
        <!-- Time Format -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Time Format:" Foreground="White" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <RadioButton Content="24-Hour" 
                             IsChecked="{Binding Is24HourFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             GroupName="TimeFormat"
                             Foreground="White"/>
                <RadioButton Content="12-Hour (AM/PM)" 
                             IsChecked="{Binding Is24HourFormat, Converter={StaticResource InvertBooleanConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             GroupName="TimeFormat" 
                             Margin="10,0,0,0"
                             Foreground="White"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Font Size -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Font Size:" Foreground="White" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Slider Grid.Column="0"
                        Minimum="10" Maximum="72" 
                        Value="{Binding ClockFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        TickFrequency="2" IsSnapToTickEnabled="True"
                        Margin="10,0,10,0"/>
                
                <TextBlock Grid.Column="1" 
                           Text="{Binding ClockFontSize, StringFormat='{}{0:F0} pt'}" 
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button Content="OK" 
                    Width="80" Height="25" 
                    Margin="0,0,10,0" 
                    Click="OkButton_Click" 
                    IsDefault="True"/>
            <Button Content="Cancel" 
                    Width="80" Height="25" 
                    Click="CancelButton_Click" 
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</UserControl>
