<UserControl x:Class="DeskViz.App.Widgets.RamWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DeskViz.App.Widgets"
             xmlns:converters="clr-namespace:DeskViz.App.Converters"
             xmlns:controls="clr-namespace:DeskViz.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Configure RAM Widget" Command="{Binding ConfigureWidgetCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="RAM Usage" 
                       Foreground="White" 
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            
            <Button x:Name="ConfigButton"
                    Grid.Column="1"
                    Content="⚙️"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ConfigButton_Click"
                    Foreground="LightGray"
                    ToolTip="Configure RAM Widget"
                    Visibility="{Binding IsConfiguring, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Width="32" Height="32"/>
        </Grid>
        
        <!-- RAM Info -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,10">
            <TextBlock Text="{Binding TotalRamFormatted}" 
                       Foreground="LightGray" 
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text=" RAM" 
                       Foreground="LightGray" 
                       TextTrimming="CharacterEllipsis"
                       Margin="3,0,0,0"/>
        </StackPanel>
        
        <!-- RAM Usage Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <controls:DeskVizProgressBar Value="{Binding RamUsagePercentage}"
                                       ProgressBrush="{Binding RamUsageColor}"
                                       Maximum="100"
                                       BarHeight="10"
                                       ShowText="False"/> 
                                       <!-- Hide text for now, can be configured later -->
        </Grid>
        
        <!-- RAM Details -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Used RAM -->
            <TextBlock Grid.Row="0" 
                       Grid.Column="0" 
                       Text="Used:" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Left"/>
            
            <TextBlock Grid.Row="0" 
                       Grid.Column="1" 
                       Text="{Binding UsedRamFormatted}" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Right"/>
            
            <!-- Available RAM -->
            <TextBlock Grid.Row="1" 
                       Grid.Column="0" 
                       Text="Free:" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Left"
                       Margin="0,5,0,0"/>
            
            <TextBlock Grid.Row="1" 
                       Grid.Column="1" 
                       Text="{Binding FreeRamFormatted}" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Right"
                       Margin="0,5,0,0"/>
        </Grid>
        
        <!-- RAM Details Additional (Page File) -->
        <Grid Grid.Row="4" Margin="0,10,0,0" Visibility="{Binding ShowPageFileInfo, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Page File Header -->
            <TextBlock Grid.Row="0" 
                       Grid.Column="0" 
                       Grid.ColumnSpan="2"
                       Text="Page File:" 
                       Foreground="LightGray" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,5"/>
            
            <!-- Page File Used -->
            <TextBlock Grid.Row="1" 
                       Grid.Column="0" 
                       Text="Used:" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Left"/>
            
            <TextBlock Grid.Row="1" 
                       Grid.Column="1" 
                       Text="{Binding PageFileUsedFormatted}" 
                       Foreground="LightGray" 
                       HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</UserControl>
