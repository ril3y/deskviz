<Window x:Class="DeskViz.App.Widgets.CpuWidgetSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:DeskViz.App.Widgets"
        mc:Ignorable="d"
        Title="CPU Widget Settings" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Update Interval -->
        <Label Grid.Row="0" Grid.Column="0" Content="Update Interval:" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="UpdateIntervalSlider" Minimum="0.5" Maximum="5" TickFrequency="0.5" Value="2.5" 
                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding ElementName=UpdateIntervalSlider, Path=Value, StringFormat={}{0:0.0} sec}" 
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <!-- Show CPU Cores -->
        <Label Grid.Row="1" Grid.Column="0" Content="Show CPU Cores:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="ShowCoresCheckBox" IsChecked="True" 
                  VerticalAlignment="Center" Margin="0,10,0,0"/>
                  
        <!-- Temperature Display Section -->
        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Temperature Display Options" 
               FontWeight="Bold" Margin="0,20,0,5"/>

        <!-- Show Temperature -->
        <Label Grid.Row="3" Grid.Column="0" Content="Show Temperature:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ShowTemperatureCheckBox" IsChecked="True" 
                  VerticalAlignment="Center" Margin="0,10,0,0"/>

        <!-- Temperature Unit -->
        <Label Grid.Row="4" Grid.Column="0" Content="Temperature Unit:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
            <RadioButton x:Name="CelsiusRadioButton" Content="Celsius (°C)" IsChecked="True" Margin="0,0,15,0" GroupName="TempUnit"/>
            <RadioButton x:Name="FahrenheitRadioButton" Content="Fahrenheit (°F)" GroupName="TempUnit"/>
        </StackPanel>

        <!-- Font Size -->
        <Label Grid.Row="5" Grid.Column="0" Content="Temperature Font Size:" VerticalAlignment="Center" Margin="0,10,10,0"/>
        <Grid Grid.Row="5" Grid.Column="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="TempFontSizeSlider" Minimum="10" Maximum="24" TickFrequency="1" Value="12" 
                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding ElementName=TempFontSizeSlider, Path=Value, StringFormat={}{0:0} pt}" 
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>
        
        <!-- CPU metrics to display -->
        <Label Grid.Row="6" Grid.Column="0" Content="Additional Metrics:" VerticalAlignment="Top" Margin="0,10,10,0"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,10,0,0">
            <CheckBox x:Name="ShowClockSpeedCheckBox" Content="Show Clock Speed" Margin="0,0,0,5"/>
            <CheckBox x:Name="ShowPowerUsageCheckBox" Content="Show Power Usage" Margin="0,0,0,5"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" Width="75" Margin="0,0,10,0" IsDefault="True" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="75" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
