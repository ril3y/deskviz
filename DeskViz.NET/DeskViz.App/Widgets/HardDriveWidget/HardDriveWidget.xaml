<UserControl x:Class="DeskViz.App.Widgets.HardDriveWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DeskViz.App.Widgets"
             xmlns:converters="clr-namespace:DeskViz.App.Converters"
             xmlns:controls="clr-namespace:DeskViz.App.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <UserControl.Resources>
        <converters:BytesToStringConverter x:Key="BytesToStringConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Configure Hard Drive Widget" Command="{Binding ConfigureWidgetCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Hard Drives"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button x:Name="ConfigButton"
                    Grid.Column="1"
                    Content="⚙️"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ConfigButton_Click"
                    Foreground="LightGray"
                    ToolTip="Configure Hard Drive Widget"
                    Visibility="{Binding IsConfiguring, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Width="32" Height="32"/>
        </Grid>

        <!-- Drive List -->
        <ItemsControl Grid.Row="1"
                      x:Name="DrivesItemsControl"
                      ItemsSource="{Binding Drives}"
                      Margin="0,15,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drive Name and Temperature -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label, StringFormat='({0})'}"
                                           Foreground="LightGray"
                                           FontSize="12"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding ShowLabel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Temperature, StringFormat='{}{0:F0}°C'}"
                                       Foreground="Orange"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowTemperature, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>

                        <!-- Usage Bar -->
                        <controls:DeskVizProgressBar Grid.Row="1"
                                     Value="{Binding UsagePercent}"
                                     ProgressBrush="{Binding UsageColor}"
                                     Maximum="100"
                                     BarHeight="10"
                                     ShowText="False"
                                     Margin="0,0,0,5"/>

                        <!-- Usage Info -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding UsagePercent, StringFormat='{}{0:F1}% used'}"
                                       Foreground="LightGray"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding UsedBytes, Converter={StaticResource BytesToStringConverter}}"
                                           Foreground="White"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" / "
                                           Foreground="LightGray"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalBytes, Converter={StaticResource BytesToStringConverter}}"
                                           Foreground="LightGray"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>