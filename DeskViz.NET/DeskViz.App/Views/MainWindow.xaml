<Window x:Class="DeskViz.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskViz.App.Views"
        xmlns:controls="clr-namespace:DeskViz.App.Controls"
        mc:Ignorable="d"
        Title="DeskViz" 
        Height="450" Width="800"
        Background="#222222"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        AllowsTransparency="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Style to add margin around each widget -->
        <!-- <Style TargetType="UserControl">
            <Setter Property="Margin" Value="10,5,10,10"/>
        </Style> -->
    </Window.Resources>
    
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Settings" Click="ContextMenuSettings_Click" />
                <Separator />
                <MenuItem Header="Exit" Click="ContextMenuExit_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/> 
            
        </Grid.RowDefinitions>
        
        <!-- Main dashboard content -->
        <ScrollViewer Grid.Row="1" 
                     Background="Transparent"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <!-- Use a WrapPanel instead to allow better spacing -->
            <WrapPanel x:Name="WidgetPanel" 
                       Orientation="Horizontal"
                       HorizontalAlignment="Center" 
                       Margin="15,10"
                       ItemWidth="NaN"
                       ItemHeight="NaN">
                <!-- Widgets will be added here dynamically -->
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
