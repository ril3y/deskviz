<Window x:Class="DeskViz.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeskViz.App.Views"
        xmlns:controls="clr-namespace:DeskViz.App.Controls"
        mc:Ignorable="d"
        Title="DeskViz" 
        Height="450" Width="800"
        Background="#222222"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Style to add margin around each widget -->
        <!-- <Style TargetType="UserControl">
            <Setter Property="Margin" Value="10,5,10,10"/>
        </Style> -->
    </Window.Resources>
    
    <Grid>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Page Settings" Click="ContextMenuPageSettings_Click" ToolTip="Configure widgets for this page"/>
                <MenuItem Header="Global Settings" Click="ContextMenuSettings_Click" ToolTip="Display and general settings"/>
                <Separator />
                <MenuItem x:Name="CurrentPageMenuItem" Header="Current Page: Main" IsEnabled="False" />
                <Separator />
                <MenuItem Header="Pages">
                    <MenuItem Header="Add New Page" Click="AddNewPage_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Click="ContextMenuExit_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/> 
            
        </Grid.RowDefinitions>
        
        <!-- Main dashboard content with paged widgets -->
        <controls:PagedWidgetContainer x:Name="PagedContainer"
                                      Grid.Row="1" 
                                      Background="Transparent"/>
    </Grid>
</Window>
