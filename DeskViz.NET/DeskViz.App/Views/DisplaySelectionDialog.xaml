<Window x:Class="DeskViz.App.Views.DisplaySelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to DeskViz - Select Display"
        Height="280"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Welcome Header -->
        <TextBlock Grid.Row="0"
                   Text="Welcome to DeskViz!"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20">
            <Run Text="Please select which display you would like DeskViz to appear on."/>
            <LineBreak/>
            <Run Text="You can change this later in Settings (press Escape while running)."
                 Foreground="Gray" FontSize="11"/>
        </TextBlock>

        <!-- Display Selection -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Display:"
                       VerticalAlignment="Center"
                       Width="60"/>
            <ComboBox x:Name="DisplayComboBox"
                      Width="320"
                      DisplayMemberPath="DisplayName"/>
        </StackPanel>

        <!-- Display Info -->
        <Border Grid.Row="3"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,15">
            <StackPanel x:Name="DisplayInfoPanel">
                <TextBlock x:Name="DisplayResolutionText" Text="Resolution: -" FontSize="12"/>
                <TextBlock x:Name="DisplayPositionText" Text="Position: -" FontSize="12"/>
                <TextBlock x:Name="DisplayPrimaryText" Text="" FontSize="12" Foreground="Green"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="90"
                    Height="28"
                    IsDefault="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
