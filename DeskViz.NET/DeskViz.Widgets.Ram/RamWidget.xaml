<local:BaseWidget x:Class="DeskViz.Widgets.Ram.RamWidget"
             xmlns:local="clr-namespace:DeskViz.Plugins.Base;assembly=DeskViz.Plugins"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <local:BaseWidget.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </local:BaseWidget.Resources>

    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="RAM Usage"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <!-- RAM Info -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="{Binding TotalRamFormatted}"
                           Foreground="LightGray"
                           FontSize="12"/>
                <TextBlock Text=" RAM"
                           Foreground="LightGray"
                           FontSize="12"
                           Margin="3,0,0,0"/>
            </StackPanel>

            <!-- RAM Usage Bar -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0"
                             x:Name="RamUsageProgressBar"
                             Maximum="100"
                             Height="20"
                             Background="#333333"
                             Foreground="{Binding RamUsageColor}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding RamUsagePercentage, StringFormat={}{0:F1}%}"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>

            <!-- RAM Details -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Used RAM -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Used:"
                           Foreground="LightGray"
                           FontSize="11"
                           HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding UsedRamFormatted}"
                           Foreground="White"
                           FontSize="11"
                           HorizontalAlignment="Right"/>

                <!-- Available RAM -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Free:"
                           Foreground="LightGray"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           Margin="0,2,0,0"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding FreeRamFormatted}"
                           Foreground="White"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           Margin="0,2,0,0"/>
            </Grid>

            <!-- Page File Info -->
            <Grid Grid.Row="4"
                  Margin="0,8,0,0"
                  Visibility="{Binding ShowPageFileInfo, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Page File Header -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Text="Page File:"
                           Foreground="LightGray"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,2"/>

                <!-- Page File Used -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Used:"
                           Foreground="LightGray"
                           FontSize="10"
                           HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding PageFileUsedFormatted}"
                           Foreground="White"
                           FontSize="10"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</local:BaseWidget>