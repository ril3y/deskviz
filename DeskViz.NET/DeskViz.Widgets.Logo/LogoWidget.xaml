<base:BaseWidget x:Class="DeskViz.Widgets.Logo.LogoWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:base="clr-namespace:DeskViz.Plugins.Base;assembly=DeskViz.Plugins"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300"
             Background="Transparent">

    <Border Background="#1E1E1E" CornerRadius="8" Padding="8" Margin="4">
        <Grid>
            <!-- No Image Placeholder -->
            <TextBlock Text="No Image Selected"
                       Foreground="Gray"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding NoImageVisibility}" />

            <!-- Image Display -->
            <Image Source="{Binding ImageSource}"
                   Width="{Binding ImageWidth}"
                   Height="{Binding ImageHeight}"
                   Stretch="{Binding ImageStretch}"
                   HorizontalAlignment="{Binding ImageHorizontalAlignment}"
                   VerticalAlignment="{Binding ImageVerticalAlignment}"
                   Visibility="{Binding ImageVisibility}" />
        </Grid>
    </Border>
</base:BaseWidget>
