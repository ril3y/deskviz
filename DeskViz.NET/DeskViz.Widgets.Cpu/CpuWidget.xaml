<local:BaseWidget x:Class="DeskViz.Widgets.Cpu.CpuWidget"
             xmlns:local="clr-namespace:DeskViz.Plugins.Base;assembly=DeskViz.Plugins"
             xmlns:cpu="clr-namespace:DeskViz.Widgets.Cpu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <local:BaseWidget.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Temperature unit converter -->
        <cpu:TemperatureUnitConverter x:Key="TemperatureUnitConverter"/>
    </local:BaseWidget.Resources>

    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="4">
        <StackPanel>
            <!-- CPU Name Header -->
            <TextBlock Text="{Binding CpuName}"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

            <!-- Overall CPU Usage -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0"
                             x:Name="OverallCpuProgressBar"
                             Maximum="100"
                             Height="20"
                             Background="#333333"
                             Foreground="{Binding OverallCpuUsageColor}"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding OverallCpuUsagePercentage, StringFormat={}{0:F1}%}"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>

            <!-- CPU Temperature -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="{Binding ShowTemperature, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Temperature: " Foreground="LightGray" FontSize="11"/>
                <TextBlock Text="{Binding CpuTemperature, StringFormat={}{0:F0}}"
                           Foreground="White"
                           FontSize="{Binding TemperatureFontSize}"/>
                <TextBlock Text="{Binding UseFahrenheit, Converter={StaticResource TemperatureUnitConverter}}"
                           Foreground="LightGray"
                           FontSize="11"
                           Margin="2,0,0,0"/>
            </StackPanel>

            <!-- CPU Clock Speed -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="{Binding ShowClockSpeed, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Clock Speed: " Foreground="LightGray" FontSize="11"/>
                <TextBlock Text="{Binding CpuClockSpeed, StringFormat={}{0:F0} MHz}"
                           Foreground="White"
                           FontSize="11"/>
            </StackPanel>

            <!-- CPU Power Usage -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding ShowPowerUsage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Power: " Foreground="LightGray" FontSize="11"/>
                <TextBlock Text="{Binding CpuPowerUsage, StringFormat={}{0:F1} W}"
                           Foreground="White"
                           FontSize="11"/>
            </StackPanel>

            <!-- CPU Cores -->
            <ItemsControl ItemsSource="{Binding CpuCores}"
                          Visibility="{Binding ShowCores, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       Foreground="LightGray"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>

                            <ProgressBar Grid.Column="1"
                                         Value="{Binding AnimatedUsagePercentage}"
                                         Maximum="100"
                                         Height="14"
                                         Background="#333333"
                                         Foreground="{Binding UsageColor}"
                                         Margin="4,0"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Percentage}"
                                       Foreground="White"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</local:BaseWidget>