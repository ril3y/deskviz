<UserControl x:Class="DeskViz.Widgets.Meshtastic.MeshtasticWidgetSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="350"
             Background="#1e1e1e">

    <StackPanel Margin="15">
        <TextBlock Text="Meshtastic Settings" FontSize="16" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,15"/>

        <!-- Connection Section -->
        <TextBlock Text="Connection" FontWeight="SemiBold" Foreground="#67e8f9" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="COM Port:" Foreground="White" VerticalAlignment="Center"/>
            <ComboBox x:Name="ComPortComboBox" Grid.Column="1" Margin="0,0,5,0"/>
            <Button x:Name="RefreshPortsButton" Grid.Column="2" Content="Refresh"
                    Padding="10,3" Click="RefreshPorts_Click"/>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Baud Rate:" Foreground="White" VerticalAlignment="Center"/>
            <ComboBox x:Name="BaudRateComboBox" Grid.Column="1">
                <ComboBoxItem Content="9600" Tag="9600"/>
                <ComboBoxItem Content="19200" Tag="19200"/>
                <ComboBoxItem Content="38400" Tag="38400"/>
                <ComboBoxItem Content="57600" Tag="57600"/>
                <ComboBoxItem Content="115200" Tag="115200" IsSelected="True"/>
                <ComboBoxItem Content="230400" Tag="230400"/>
                <ComboBoxItem Content="460800" Tag="460800"/>
                <ComboBoxItem Content="921600" Tag="921600"/>
            </ComboBox>
        </Grid>

        <CheckBox x:Name="AutoConnectCheckBox" Content="Auto-connect on startup"
                  Foreground="White" IsChecked="True" Margin="0,0,0,10"/>

        <!-- Connection Test -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="ConnectButton" Content="Connect" Padding="15,5"
                    Margin="0,0,10,0" Click="Connect_Click"/>
            <Button x:Name="DisconnectButton" Content="Disconnect" Padding="15,5"
                    Click="Disconnect_Click"/>
            <TextBlock x:Name="ConnectionStatusText" Text="" Foreground="#94a3b8"
                       VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <Separator Background="#333" Margin="0,5,0,15"/>

        <!-- Display Section -->
        <TextBlock Text="Display Options" FontWeight="SemiBold" Foreground="#67e8f9" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowGpsCheckBox" Content="Show GPS information"
                  Foreground="White" IsChecked="True" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowNodesCheckBox" Content="Show node list"
                  Foreground="White" IsChecked="True" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowSignalCheckBox" Content="Show signal strength"
                  Foreground="White" IsChecked="True" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowChannelsCheckBox" Content="Show channels"
                  Foreground="White" IsChecked="True" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowTelemetryCheckBox" Content="Show telemetry data"
                  Foreground="White" IsChecked="True" Margin="0,0,0,8"/>

        <CheckBox x:Name="ShowMessagesCheckBox" Content="Show messages"
                  Foreground="White" IsChecked="True" Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Font Size:" Foreground="White" VerticalAlignment="Center"/>
            <Slider x:Name="FontSizeSlider" Grid.Column="1" Minimum="8" Maximum="24"
                    Value="12" TickFrequency="1" IsSnapToTickEnabled="True"/>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Show Messages:" Foreground="White" VerticalAlignment="Center"/>
            <Slider x:Name="DisplayMessageCountSlider" Grid.Column="1" Minimum="1" Maximum="20"
                    Value="5" TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="DisplayMessageCountSlider_ValueChanged"/>
            <TextBlock x:Name="DisplayMessageCountLabel" Grid.Column="2" Text="5"
                       Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="20"/>
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Max Messages:" Foreground="White" VerticalAlignment="Center"/>
            <TextBox x:Name="MaxMessagesTextBox" Grid.Column="1" Text="50"/>
        </Grid>

        <Separator Background="#333" Margin="0,5,0,15"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Padding="20,8"
                    Margin="0,0,10,0" Click="Save_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" Padding="20,8"
                    Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</UserControl>
