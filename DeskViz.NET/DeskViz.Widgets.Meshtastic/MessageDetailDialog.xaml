<Window x:Class="DeskViz.Widgets.Meshtastic.MessageDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message Detail"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="400"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#444" BorderThickness="1" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Signal info -->
                <RowDefinition Height="Auto"/>  <!-- Separator -->
                <RowDefinition Height="Auto"/>  <!-- Message text -->
                <RowDefinition Height="Auto"/>  <!-- Separator -->
                <RowDefinition Height="Auto"/>  <!-- Reply section -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header: Sender + Timestamp -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SenderText" FontWeight="Bold" FontSize="16" Foreground="LimeGreen"/>
                <TextBlock x:Name="TimestampText" Grid.Column="1" FontSize="12" Foreground="Gray"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Signal Info -->
            <TextBlock x:Name="SignalText" Grid.Row="1" FontSize="11" Foreground="Gray" Margin="0,0,0,8"/>

            <!-- Separator -->
            <Rectangle Grid.Row="2" Height="1" Fill="#444" Margin="0,4"/>

            <!-- Message Text -->
            <TextBlock x:Name="MessageText" Grid.Row="3" FontSize="14" Foreground="White"
                       TextWrapping="Wrap" Margin="0,12" MaxHeight="200"/>

            <!-- Separator -->
            <Rectangle Grid.Row="4" Height="1" Fill="#444" Margin="0,4"/>

            <!-- Reply Section -->
            <StackPanel Grid.Row="5" Margin="0,8,0,0">
                <TextBlock Text="Reply" FontSize="12" Foreground="LightGray" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ReplyTextBox" Background="#333" Foreground="White"
                             BorderBrush="#555" BorderThickness="1" Padding="8,6"
                             FontSize="13" VerticalAlignment="Center"
                             KeyDown="ReplyTextBox_KeyDown"/>
                    <Button x:Name="SendButton" Grid.Column="1" Content="Send" Padding="16,6"
                            Margin="8,0,0,0" Click="Send_Click"
                            Background="#2563EB" Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
                <TextBlock x:Name="StatusText" FontSize="11" Foreground="Gray" Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Close Button -->
            <Button Grid.Row="6" Content="Close" Padding="16,6" Margin="0,12,0,0"
                    HorizontalAlignment="Right" Click="Close_Click"
                    Background="#333" Foreground="White" BorderBrush="#555" BorderThickness="1"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
