<base:BaseWidget x:Class="DeskViz.Widgets.Meshtastic.MeshtasticWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:base="clr-namespace:DeskViz.Plugins.Base;assembly=DeskViz.Plugins"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="350"
             Background="Transparent">

    <base:BaseWidget.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </base:BaseWidget.Resources>

    <Border Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="4">
        <Grid>
            <!-- Main content -->
            <StackPanel>
                <!-- Header with connection status -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Meshtastic" FontWeight="Bold" FontSize="16" Foreground="White"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding ConnectionColor}" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding ConnectionStatusText}"
                                   FontSize="10" Foreground="LightGray"/>
                    </StackPanel>
                </Grid>

                <!-- Not Connected placeholder (shown instead of data sections) -->
                <Border Background="#2A2A2A" CornerRadius="6" Padding="20" MinHeight="120"
                        Visibility="{Binding NoConnectionVisibility}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE871;" FontFamily="Segoe MDL2 Assets" FontSize="28"
                                   Foreground="#555" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Not Connected" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#888" HorizontalAlignment="Center"/>
                        <TextBlock Text="Configure COM port in widget settings" FontSize="10"
                                   Foreground="#555" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Connected content - all data sections hidden when not connected -->
                <StackPanel Visibility="{Binding ConnectedContentVisibility}">

                <!-- Channels Section -->
                <Border Background="#333333" CornerRadius="4" Padding="8" Margin="0,0,0,6"
                        Visibility="{Binding ChannelsVisibility}">
                    <StackPanel>
                        <TextBlock Text="Channels" FontWeight="SemiBold" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding ChannelItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#555" CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RoleText}" FontSize="9" Foreground="White"
                                                       FontWeight="Bold"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="10"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding MessageCount, StringFormat={}{0} msgs}"
                                                   FontSize="9" Foreground="Gray" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- GPS and Network Info Panel -->
                <Border Background="#333333" CornerRadius="4" Padding="8" Margin="0,0,0,6"
                        Visibility="{Binding GpsInfoVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GPS" FontWeight="SemiBold" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sats: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding GpsSatellites}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lat: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Latitude, StringFormat=F6}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lon: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Longitude, StringFormat=F6}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Alt: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Altitude}" FontSize="10" Foreground="White"/>
                                <TextBlock Text="m" FontSize="10" Foreground="LightGray" Margin="2,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Network" FontWeight="SemiBold" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Node: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding MyNodeId}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Nodes: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding ConnectedNodes}" FontSize="10" Foreground="LimeGreen"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="FW: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding FirmwareVersion}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Batt: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding BatteryLevel}" FontSize="10" Foreground="{Binding BatteryColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Telemetry Section -->
                <Border Background="#333333" CornerRadius="4" Padding="8" Margin="0,0,0,6"
                        Visibility="{Binding TelemetryVisibility}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Device" FontWeight="SemiBold" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ChUtil: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding ChannelUtilization}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="AirTx: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding AirUtilTx}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Uptime: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Uptime}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Voltage: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Voltage}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Environment" FontWeight="SemiBold" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Temp: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Temperature}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Humid: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Humidity}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Press: " FontSize="10" Foreground="LightGray"/>
                                <TextBlock Text="{Binding Pressure}" FontSize="10" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Node List Section -->
                <Border Background="#333333" CornerRadius="4" Padding="8" Margin="0,0,0,6"
                        Visibility="{Binding NodeListVisibility}">
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Node List" FontWeight="SemiBold" FontSize="11" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="{Binding ConnectedNodes, StringFormat={}{0} nodes}"
                                       FontSize="9" Foreground="Gray"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                            <ItemsControl ItemsSource="{Binding NodeItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D2D2D" CornerRadius="3" Margin="0,1" Padding="6,3"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#555" CornerRadius="2" Padding="4,1" Margin="0,0,6,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ShortName}" FontSize="9"
                                                               Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="10" Foreground="White"/>
                                                        <TextBlock Text="{Binding HwModel}" FontSize="9" Foreground="Gray"
                                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding MqttBadge}" FontSize="8" Foreground="#f59e0b"
                                                                   Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                            HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding LastHeardText}" FontSize="9" Foreground="Gray"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding HopsText}" FontSize="8" Foreground="Gray"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Chat Messages Section -->
                <Border Background="#333333" CornerRadius="4" Padding="4"
                        Visibility="{Binding MessagesVisibility}">
                    <DockPanel>
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="4,2,4,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Chat" FontWeight="SemiBold" FontSize="12" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding MessageCount, StringFormat={}{0} msgs}"
                                       FontSize="10" Foreground="LightGray"/>
                        </Grid>

                        <!-- Chat area with fixed min height -->
                        <Grid MinHeight="120">
                            <!-- Empty state -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding NoChatMessagesVisibility}">
                                <TextBlock Text="No messages yet" FontSize="12" Foreground="#555"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Messages will appear here" FontSize="10" Foreground="#444"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Message list -->
                            <ScrollViewer x:Name="ChatScrollViewer"
                                          VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding DisplayMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2A2A2A" CornerRadius="6" Margin="2,2" Padding="8,6"
                                                    Cursor="Hand" MouseLeftButtonUp="Message_Click">
                                                <StackPanel>
                                                    <!-- Sender row -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="#444" CornerRadius="2" Padding="4,1" Margin="0,0,5,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ChannelName}" FontSize="8"
                                                                           Foreground="#67e8f9"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding SenderName}" FontWeight="SemiBold"
                                                                       FontSize="11" Foreground="#4ade80"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding SignalInfo}" FontSize="8"
                                                                       Foreground="#666" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding TimeString}"
                                                                       FontSize="9" Foreground="#888"/>
                                                        </StackPanel>
                                                    </Grid>
                                                    <!-- Message text -->
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="{Binding FontSize}" Foreground="#E0E0E0"
                                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                </StackPanel> <!-- End connected content wrapper -->
            </StackPanel>
        </Grid>
    </Border>
</base:BaseWidget>
